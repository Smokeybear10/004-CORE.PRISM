# Copy to .env and fill in. .env is gitignored; .env.example is committed.
#
# Anthropic API key — used by model/attribution/run.py and coherence.py.
# Without this, model.attribute() falls back to the synthetic placeholder
# and the demo's source badge reads "mock fallback".
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME

# Opt in to LIVE Claude attributions in model.attribute(). Default OFF so
# tests/CI never silently bill the API. Set to "1" for the demo and any
# real-data backtest. When OFF, model.attribute() returns the synthetic
# placeholder; when ON it tries run_attribution and falls back to the
# placeholder on any error (auth, validation, transient network).
BW_USE_LIVE_ATTRIBUTION=1

# Finnhub historical news (free signup at finnhub.io/register). Optional.
# When set, demo/real_chunks.preload_finnhub_news fetches ~5 years of
# company news per focal + peer ticker and unions it with the bundled
# Yahoo Finance parquet (which only covers 2025-03 onwards). No-op when
# unset — the demo still works, you just get fewer News / Peer-news
# chunks on older flagged moves.
FINNHUB_API_KEY=
