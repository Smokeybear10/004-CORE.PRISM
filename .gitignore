# Python
venv/
.venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

# Cached scraped / fetched data (yfinance, SEC, news, macro)
.cache/
**/.cache/
*.parquet
data/raw/

# Environment / secrets
.env
.env.local
*.pem

# macOS
.DS_Store

# Claude Code local settings
.claude/settings.local.json
.agents/

# HuggingFace datasets library clone (not project data)
datasets/

# Editors
.vscode/
.idea/
*.swp

# Local data / caches (HF pulls, parquet caches, etc. — never commit raw bulk data).
# Ignore everything under top-level data/ EXCEPT the small focal_chunks.jsonl
# the demo's 13F preloader reads at startup. (gitignore can't re-include files
# whose parent directory is excluded, so we must use data/* not data/.)
data/*
!data/thirteen_f/
data/thirteen_f/*
!data/thirteen_f/focal_chunks.jsonl

# demo/static/data/ holds the pre-baked per-ticker JSON bundles (~1 MB total).
# Without these a fresh clone shows "Error loading data" on the demo page
# until `python demo/build_static.py` is run.
!demo/static/data/
!demo/static/data/*.json
# Generated backtest outputs
out/
.gstack/
